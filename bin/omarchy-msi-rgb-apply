#!/usr/bin/env python3
"""
Apply MSI RGB pattern using the current omarchy theme colors.

Called from the omarchy theme-set hook. Reads pattern/brightness
preferences from ~/.config/omarchy/msi-rgb.toml (if present) and
derives colors from the active theme:

  keyboard: primary = accent, secondary = color1
  lightbar: color = accent

Exits silently if devices are not available (e.g., wrong machine).
"""

import sys
import os

# Add the library path (for running from the source tree)
_lib_dir = os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib")
if os.path.isdir(_lib_dir):
    sys.path.insert(0, _lib_dir)

from omarchy_msi_rgb.config import load_config
from omarchy_msi_rgb.theme import load_theme_colors
from omarchy_msi_rgb.patterns import generate_keyboard_colors, generate_lightbar_color
from omarchy_msi_rgb.core import KeyboardRGB, LightbarRGB, HIDAPIError


def main():
    config = load_config()
    colors = load_theme_colors()

    errors = []

    # Apply keyboard pattern
    kb_cfg = config.get("keyboard", {})
    try:
        kb = KeyboardRGB()
        if kb.is_available():
            msi_colors = generate_keyboard_colors(
                pattern=kb_cfg.get("pattern", "gradient-h"),
                theme_colors=colors,
                primary="accent",
                secondary="color1",
                brightness=kb_cfg.get("brightness", 100),
            )
            kb.set_per_key(msi_colors)
    except HIDAPIError as e:
        errors.append(f"Keyboard: {e}")
    except Exception as e:
        errors.append(f"Keyboard: {e}")

    # Apply lightbar color
    lb_cfg = config.get("lightbar", {})
    try:
        lb = LightbarRGB()
        if lb.is_available():
            lb_color = generate_lightbar_color(
                pattern="solid",
                theme_colors=colors,
                color_ref="accent",
                brightness=lb_cfg.get("brightness", 100),
            )
            lb.set_all(*lb_color)
    except HIDAPIError as e:
        errors.append(f"Lightbar: {e}")
    except Exception as e:
        errors.append(f"Lightbar: {e}")

    if errors:
        for err in errors:
            print(f"omarchy-msi-rgb: {err}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
